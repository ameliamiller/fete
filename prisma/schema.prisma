generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id            String   @id @default(cuid())
  title         String
  emoji         String
  date          DateTime
  location      String
  description   String
  hostName      String
  hostPhone     String
  cohostPhones  String[] @default([])
  shortUrl      String?
  slug          String?  @unique
  createdAt     DateTime @default(now())

  rsvps      Rsvp[]
  messages   MockMessage[]
  wallPosts  WallPost[]
}

model Rsvp {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  phone     String
  status    String   // "GOING" | "MAYBE" | "NOT_GOING"
  smsOptIn  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, phone])
}

model MagicLink {
  id        String    @id @default(cuid())
  phone     String
  token     String    @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model WallPost {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  message   String
  x         Float    // 0–100, percent from left
  y         Float    // 0–100, percent from top
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model MockMessage {
  id        String   @id @default(cuid())
  eventId   String
  toPhone   String
  toName    String
  body      String
  type      String   // "reminder"
  sentAt    DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
